# ── Secrets (NEVER commit) ──────────────────────────────────────────────
.env
.env.*
!.env.template
*.key
.api_key_*

# ── Python ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/

# ── Virtual environments ───────────────────────────────────────────────
.venv/
venv/
ENV/

# ── uv ─────────────────────────────────────────────────────────────────
.python-version

# ── Checkpoint & runtime databases ────────────────────────────────────
.council/

# ── IDE / editor ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

