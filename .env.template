# ──────────────────────────────────────────────────────────────────────────────
# Deliberative Council — API Keys
# ──────────────────────────────────────────────────────────────────────────────
#
# Copy this file to .env and fill in your keys:
#   cp .env.template .env
#   nano .env
#
# KEY SAFETY:
#   - NEVER commit .env to version control (it's in .gitignore)
#   - All free-tier keys have ZERO financial risk (no credit card needed)
#   - SambaNova: Non-regenerating $5 credits; deprioritized to conserve
#
# PRIORITY ORDER (as configured in config/providers.yaml):
#   0. Cloudflare Workers AI  — 10K neurons/day, DAILY REGEN, 55 LLM models
#   1. OpenRouter free models — 50 RPD, 28 free models, good diversity
#   2. Gemini                 — 1,500 RPD, GEO-BLOCKED from HK
#   3. Groq                   — ~14,400 RPD, GEO-BLOCKED from HK
#   4. SambaNova              — $5 credits (non-regenerating), conserve
#   5. Cerebras               — Limited (non-regenerating), GEO-BLOCKED from HK
# ──────────────────────────────────────────────────────────────────────────────

# ── Priority 0: Cloudflare Workers AI (10K neurons/day, DAILY REGEN) ────────
# Get token: https://dash.cloudflare.com/profile/api-tokens
# Get account ID: https://dash.cloudflare.com/ (in URL after login)
# No credit card required
# 55 LLM models including Llama, Qwen, DeepSeek, Gemma, Mistral, etc.
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
# Auto-generated from account ID (do not edit):
CLOUDFLARE_API_BASE=https://api.cloudflare.com/client/v4/accounts/${CLOUDFLARE_ACCOUNT_ID}/ai/v1

# ── Priority 1: OpenRouter (28 free models, 50 RPD) ─────────────────────────
# Get key: https://openrouter.ai/settings/keys
# No credit card required for free models
# Free models use ":free" suffix in model ID
# Rate limits: 20 RPM, 50 RPD (free tier); 1,000 RPD if $10+ credits purchased
OPENROUTER_API_KEY=

# ── Priority 2: Google Gemini (1,500 RPD, GEO-BLOCKED from HK) ─────────────
# Get key: https://aistudio.google.com/apikey
# No credit card required
# NOTE: 403 Forbidden from Hong Kong — route through OpenRouter instead
GEMINI_API_KEY=

# ── Priority 3: Groq (~14,400 RPD, GEO-BLOCKED from HK) ────────────────────
# Get key: https://console.groq.com/keys
# No credit card required
# NOTE: 403 Forbidden from Hong Kong
GROQ_API_KEY=

# ── Priority 4: SambaNova ($5 credits, NON-REGENERATING) ────────────────────
# Get key: https://cloud.sambanova.ai/
# $5 free credits on signup — ONCE, does not regenerate
SAMBANOVA_API_KEY=

# ── Priority 5: Cerebras (limited, GEO-BLOCKED from HK) ─────────────────────
# Get key: https://cloud.cerebras.ai/
# Very limited free tier; also geo-blocked from HK
CEREBRAS_API_KEY=
